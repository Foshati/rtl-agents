{
  "publisher": "Foshati",
  "name": "rtl-agents",
  "displayName": "RTL Agents",
  "version": "1.7.7",
  "packageManager": "pnpm@10.22.0",
  "description": "Professional RTL/LTR toggle support for AI Chats (Cursor, VS Code, Windsurf, VSCodium, Antigravity) with code block alignment safety.",
  "author": "Foshati",
  "license": "MIT",
  "homepage": "https://github.com/Foshati/rtl-agents",
  "repository": {
    "type": "git",
    "url": "https://github.com/Foshati/rtl-agents"
  },
  "keywords": [
    "rtl",
    "ltr",
    "toggle",
    "bidi",
    "cursor",
    "antigravity",
    "windsurf",
    "persian",
    "arabic",
    "hebrew",
    "chat"
  ],
  "categories": [
    "Other"
  ],
  "main": "./dist/index.js",
  "icon": "public/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "rtl-agents.add",
        "title": "RTL Agents: Activate RTL"
      },
      {
        "command": "rtl-agents.remove",
        "title": "RTL Agents: Deactivate RTL"
      },
      {
        "command": "rtl-agents.status",
        "title": "RTL Agents: Check Status"
      },
      {
        "command": "rtl-agents.restart",
        "title": "RTL Agents: Restart RTL"
      },
      {
        "command": "rtl-agents.toggle",
        "title": "RTL Agents: Toggle RTL/LTR"
      }
    ],
    "configuration": {
      "title": "RTL Agents",
      "properties": {
        "rtl-agents.customSelectors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional custom CSS selectors where RTL direction toggle should be applied."
        },
        "rtl-agents.rtlCharacterRegex": {
          "type": "string",
          "default": "[\\u0590-\\u05FF\\u0600-\\u06FF\\u0750-\\u077F\\u08A0-\\u08FF\\uFB50-\\uFDFF\\uFE70-\\uFEFF]",
          "description": "Regular expression pattern used to detect Right-To-Left characters (Hebrew, Arabic, Persian, etc.)."
        }
      }
    },
    "keybindings": [
      {
        "command": "rtl-agents.toggle",
        "key": "ctrl+alt+r",
        "mac": "ctrl+cmd+r"
      }
    ]
  },
  "scripts": {
    "build": "tsup src/index.ts --external vscode",
    "lint": "eslint .",
    "vscode:prepublish": "pnpm build"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@types/node": "^25.0.3",
    "@types/vscode": "^1.80.0",
    "eslint": "^9.39.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
